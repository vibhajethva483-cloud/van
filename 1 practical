#factorial code

using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

class program
{
    static void Main()
    {
        int num, fact = 1;

        Console.Write("Enter a number:");
        num = int.Parse(Console.ReadLine());

        for (int i = 1; i <= num; i++)
        {
            fact = fact * i;
        }
        Console.WriteLine("Factorial = " + fact);
        Console.ReadLine();
    }
}

#fabonnaci series
class program
{
    static void Main()
    {
        int n1 = 0, n2 = 1, n3, i, num;

        Console.Write("Enter the number of terms: ");
        num = int.Parse(Console.ReadLine());

        Console.Write(n1 + " " + n2 + " ");
        Console.ReadLine();
        for (i = 2; i < num; i++)
        {
            n3 = n1 + n2;
            Console.Write(n3 + " ");
            Console.ReadLine();
            n1 = n2;
            n2 = n3;
        }
    }
}

#minimum array
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

class program
{
    static void Main()
    {
        int n;
        Console.Write("Enter a number of elements: ");
        n = int.Parse(Console.ReadLine());

        int[] arr = new int[n];

        Console.WriteLine("Enter the elements: ");
        for(int i = 0; i < n; i++)
        {
            arr[i] = int.Parse(Console.ReadLine());
        }
        int min = arr[0];
        
        for (int i = 1; i < n; i++)
        {
            if (arr[i] < min)
            {
                min = arr[i];
            }
        }
        Console.WriteLine("Smallest Value : " + min);
        Console.ReadLine();
    }
}

#copy,sort,index
using System;

class Program
{
    static void Main(string[] args)
    {
        int[] a = new int[5];

        Console.WriteLine("Enter 5 Elements of array:");
        for (int i = 0; i < a.Length; i++)
        {
            a[i] = int.Parse(Console.ReadLine());
        }

        int[] b = new int[5];

        Console.WriteLine("Original Array:");
        Console.WriteLine(string.Join(" ", a));

        Array.Sort(a);
        Console.WriteLine("Sorted Array:");
        Console.WriteLine(string.Join(" ", a));

        Array.Copy(a, b, a.Length);
        Console.WriteLine("Copied Array:");
        Console.WriteLine(string.Join(" ", b));

        Console.WriteLine("Index of 4: " + Array.IndexOf(a, 4));

        Console.ReadLine();
    }
}

#armstong number
using System;

class Program
{
    static void Main()
    {
        Console.Write("Enter a number: ");
        int num = Convert.ToInt32(Console.ReadLine());

        int original = num;
        int sum = 0;

        while (num > 0)
        {
            int digit = num % 10;
            sum = sum + (digit * digit * digit);
            num = num / 10;
        }

        if (sum == original)
            Console.WriteLine("Armstrong number");
        else
            Console.WriteLine("Not an Armstrong number");

        Console.ReadLine();
    }
}
