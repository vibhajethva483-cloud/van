using System.Web;
using System.Web.Mvc;
using pracc5.Models;

namespace pracc5.Controllers
{
    public class MystudentController : Controller
    {
        // GET: Mystudent
        public ActionResult Display()
        {
            Student st = new Student();
            st.RollNo = 22;
            st.Uid = "24BIT022";

            st.FirstName ="Vibha";
            st.LastName = "Jethwa";
            st.Course = "Sybsc";



            return View(st);
        }
    }
}

