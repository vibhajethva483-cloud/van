#function overloading

using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace ConsoleApplication1
{
    class Program
    {
        public void add(int a, int b)
        {
            Console.WriteLine("Addition: " + a + "and" + b + " is:" + (a + b));
        }

        public void add(string a, string b)
        {
            Console.WriteLine("Hello" + a + "and" + b);
        }

        static void Main(string[] args)
        {
            Console.WriteLine("Enter num 1: ");
            int num1 = Convert.ToInt32(Console.ReadLine());
            Console.WriteLine("Enter num 2: ");
            int num2 = Convert.ToInt32(Console.ReadLine());

            Console.Write("Enter string 1:");
            String str1 = Console.ReadLine();
            Console.Write("Enter string 2:");
            String str2 = Console.ReadLine();

            Program obj1 = new Program();
            obj1.add(num1, num2);
            obj1.add(str1, str2);

            Console.Read();
        }
    }
}

# construnctor overloading

using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace prac2
{
    class Program
    {
        public void program(int a, int b)
        {
            int c;
            c = a;
            a = b;
            b = c;
            Console.WriteLine("Value of integer a and b before swaping is: " + a + " " + b + " respectively");
        }

        public void program(float a, float b)
        {
            float c;
            c = a;
            a = b;
            b = c;
            Console.WriteLine("Value of float a and b before swaping is: " + a + " " + b + " respectively");
        }

        static void Main(string[] args)
        {
            Console.Write("Enter 2 numbers: ");
            int num1 = int.Parse(Console.ReadLine());
            int num2 = int.Parse(Console.ReadLine());

            Console.Write("Enter 2 Float values: ");
            float st1 = float.Parse(Console.ReadLine());
            float st2 = float.Parse(Console.ReadLine());

            Program obj1 = new Program();

            Console.WriteLine("Value of integer a and b before swaping is: " + num1 + " " + num2 + "respectively");
            obj1.program(num1, num2);

            Console.WriteLine("Value of float a and b before swaping is: " + st1 + " " + st2 + "respectively");
            obj1.program(st1, st2);

            Console.Read();
        }
    }
}

#inheritance (hierarical)

using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace ConsoleApplication1
{
    interface Drawable
    {
        void draw();
    }

    public class Rectangle : Drawable
    {
        public void draw()
        {
            Console.WriteLine("drawing rectangle");
        }
    }

    public class Circle : Drawable
    {
        public void draw()
        {
            Console.WriteLine("drawing circle");
        }
    }

    public class a_3
    {
        static void Main(string[] args)
        {
            Drawable d = new Rectangle();
            d.draw();

            d = new Circle();
            d.draw();

            Console.Read();
        }
    }
}

#exception handling

using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace ConsoleApplication1
{
    class NotEvenException : Exception
    {
        public NotEvenException(string msg)
            : base(msg)
        {
        }
    }
}

namespace ConsoleApplication1
{
    class Program
    {
        static void Main(String[] ar)
        {
            int num;
            try
            {
                Console.Write("Enter a number: ");
                num = int.Parse(Console.ReadLine());
                if ((num % 2) != 0) throw new NotEvenException("Not an even number");
                else
                    Console.WriteLine("It is an even number");
            }
            catch (NotEvenException e)
            {
                Console.WriteLine(e.Message);
            }
            Console.Read();
        }
    }
}


#delegates
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace prac2
{
    public delegate void AddDel();

    class Addition
    {
        public static void Integers()
        {
            Console.WriteLine("Addition of integer 2 and 3 is: " + (2 + 3));
        }

        public static void Floats()
        {
            Console.WriteLine("Addition of Float 2.1 and 3.1 is: " + (2.1 + 3.1));
        }

        public static void Strings()
        {
            Console.WriteLine("Addition of 2 string is: hello bob");
        }

        AddDel[] ad = new AddDel[3];

        public void Identify()
        {
            ad[0] = new AddDel(Integers);
            ad[1] = new AddDel(Floats);
            ad[2] = new AddDel(Strings);
        }

        public void Display()
        {
            ad[0]();
            ad[1]();
            ad[2]();
        }
    }

    class Program
    {
        static void Main(string[] args)
        {
            Addition ts = new Addition();
            ts.Identify();
            ts.Display();
            Console.Read();
        }
    }
}
